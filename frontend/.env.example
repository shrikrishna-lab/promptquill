# PromptQuill Frontend — Environment Variables
# 1. cp .env.example .env
# 2. Fill in YOUR values
# 3. npm run dev

# ─── Supabase (YOUR project) ──────────────────────────
# https://app.supabase.com → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Backend URL ─────────────────────────────────────
VITE_BACKEND_URL=

# ─── App URL (for SEO, social meta tags) ─────────────
VITE_APP_URL=
