{
  "name": "prompter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node \"../node_modules/vite/bin/vite.js\" --port 3001 --host",
    "prebuild": "node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true});\"",
    "build": "node -e \"const fs=require('fs');const cp=require('child_process');const p=fs.existsSync('node_modules/vite/bin/vite.js')?'node_modules/vite/bin/vite.js':'../node_modules/vite/bin/vite.js';cp.execFileSync(process.execPath,[p,'build'],{stdio:'inherit'});\"",
    "lint": "node \"../node_modules/eslint/bin/eslint.js\" . --max-warnings 0",
    "test": "npm run lint && npm run build",
    "preview": "node \"../node_modules/vite/bin/vite.js\" preview"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@studio-freight/lenis": "^1.0.42",
    "@supabase/supabase-js": "^2.101.1",
    "canvas-confetti": "^1.9.4",
    "framer-motion": "^12.38.0",
    "gsap": "^3.15.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^1.3.0",
    "react-hot-toast": "^2.6.0",
    "react-is": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.1",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "terser": "^5.46.1",
    "vite": "^8.0.7"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom"
  },
  "resolutions": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
