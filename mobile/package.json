{
  "name": "promptquill-mobile",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "PromptQuill Capacitor mobile app workspace isolated from the web frontend.",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js --config vite.config.mobile.js --mode mobile --host 0.0.0.0 --port 5173",
    "build:mobile": "node ./node_modules/vite/bin/vite.js build --config vite.config.mobile.js --mode mobile",
    "sync": "node ./node_modules/@capacitor/cli/bin/capacitor sync",
    "build:and:sync": "npm run build:mobile && npm run sync",
    "open:android": "node ./node_modules/@capacitor/cli/bin/capacitor open android",
    "open:ios": "node ./node_modules/@capacitor/cli/bin/capacitor open ios",
    "test:android:apk": "node ./scripts/build-debug-apk.mjs",
    "test:android:usb": "node ./scripts/run-android-usb.mjs",
    "test:android:emulator": "node ./scripts/run-android-emulator.mjs",
    "dev:mobile": "node ./scripts/dev-mobile.mjs",
    "deploy:apk": "node ./scripts/build-debug-apk.mjs",
    "release:apk": "node ./scripts/build-release-apk.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.4",
    "@capacitor/app": "^7.1.0",
    "@capacitor/browser": "^7.0.5",
    "@capacitor/core": "^7.4.4",
    "@capacitor/haptics": "^7.0.2",
    "@capacitor/ios": "^7.4.4",
    "@capacitor/push-notifications": "^7.0.3",
    "@capacitor/share": "^7.0.2",
    "@capacitor/splash-screen": "^7.0.3",
    "@capacitor/status-bar": "^7.0.3",
    "@capgo/native-purchases": "^7.6.1",
    "@gsap/react": "^2.1.2",
    "@studio-freight/lenis": "^1.0.42",
    "@supabase/supabase-js": "^2.101.1",
    "canvas-confetti": "^1.9.4",
    "capacitor-secure-storage-plugin": "^0.13.0",
    "framer-motion": "^12.38.0",
    "gsap": "^3.15.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^1.3.0",
    "react-hot-toast": "^2.6.0",
    "react-is": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.1",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.4",
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "qrcode-terminal": "^0.12.0",
    "terser": "^5.46.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.7"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom"
  },
  "resolutions": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
