{
  "build": {
    "builder": "nixpacks",
    "buildCommand": "npm run railway:build"
  },
  "deploy": {
    "startCommand": "npm run railway:start",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 100,
    "restartPolicyMaxRetries": 5
  },
  "plugins": {
    "nodejs": {
      "version": "20.19.0"
    }
  }
}
